{
  "name": "orchestra",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestra · Human-AgentOS — control plane for hybrid human + AI workforce",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @orchestra/db migrate",
    "db:seed": "pnpm --filter @orchestra/db seed",
    "db:reset": "pnpm --filter @orchestra/db reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
