# ─────────────────────────────────────────────────────────────
# Orchestra · env template. Copy to .env.local and fill.
# NEVER commit real keys. Service role key is server-only.
# ─────────────────────────────────────────────────────────────

# Supabase (Founder B · packages/db owns migrations & RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — writes to decisions/executions bypass RLS

# Qwen Cloud API (OpenAI-compatible endpoint; Founder A · packages/ai)
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

# Observability
# TRACE_SAMPLE_RATE=1.0
